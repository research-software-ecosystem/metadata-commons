@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

bioconda:exparna a schema1:SoftwareApplication ;
    schema1:description "The program finds the longest common subsequence of exact pattern matches (LCS-EPM)" ;
    schema1:downloadUrl "https://github.com/BackofenLab/ExpaRNA/archive/1.0.1.tar.gz" ;
    schema1:identifier biotools:exparna ;
    schema1:license "GPL-2.0" ;
    schema1:name "exparna" ;
    schema1:softwareVersion "1.0.1" ;
    schema1:url "https://github.com/BackofenLab/ExpaRNA" .

