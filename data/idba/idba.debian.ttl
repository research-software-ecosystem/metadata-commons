@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:idba a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts174",
        "doi:10.1093/bioinformatics/btt219" ;
    schema1:identifier biotools:idba,
        bioconda:idba,
        scicrunch:SCR_011912 ;
    schema1:license "unknown" ;
    schema1:name "idba" ;
    schema1:softwareVersion "1.1.3" ;
    schema1:url "https://github.com/loneknightpy/idba" .

