@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .

debianmed:iva a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv120" ;
    schema1:identifier biotools:iva,
        bioconda:iva,
        "omictools:OMICS_08188" ;
    schema1:license "unknown" ;
    schema1:name "iva" ;
    schema1:softwareVersion "1.0.11+ds" ;
    schema1:url "https://github.com/sanger-pathogens/iva" .

