@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:cgview a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bti054" ;
    schema1:identifier biotools:cgview,
        bioconda:cgview,
        scicrunch:SCR_011779,
        "omictools:OMICS_00905" ;
    schema1:license "unknown" ;
    schema1:name "cgview" ;
    schema1:softwareVersion "0.0.20100111" ;
    schema1:url "http://wishart.biology.ualberta.ca/cgview/" .

