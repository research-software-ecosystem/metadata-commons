@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:jalview a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp033",
        "doi:10.1093/bioinformatics/btr304" ;
    schema1:identifier biotools:jalview,
        bioconda:jalview,
        scicrunch:SCR_006459,
        "omictools:OMICS_00885" ;
    schema1:license "unknown" ;
    schema1:name "jalview" ;
    schema1:softwareVersion "2.11.5.0" ;
    schema1:url "https://www.jalview.org" .

