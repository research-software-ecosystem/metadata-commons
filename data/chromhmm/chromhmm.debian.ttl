    schema1:citation "doi:10.1038/nmeth.1906",
        "doi:10.1038/nprot.2017.124" ;
    schema1:identifier biotools:chromhmm,
        bioconda:chromhmm,
        "omictools:OMICS_03490" ;
    schema1:license "unknown" ;
    schema1:name "chromhmm" ;
    schema1:softwareVersion "1.27" ;
    schema1:url "https://compbio.mit.edu/ChromHMM/" .

