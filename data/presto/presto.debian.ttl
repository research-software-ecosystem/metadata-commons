@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:presto a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btu138" ;
    schema1:identifier biotools:presto,
        bioconda:presto,
        scicrunch:SCR_013285,
        "omictools:OMICS_03443" ;
    schema1:license "unknown" ;
    schema1:name "presto" ;
    schema1:softwareVersion "0.7.6" ;
    schema1:url "https://presto.readthedocs.io" .

