@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

bioconda:salmon a schema1:SoftwareApplication ;
    schema1:author "k3yavi",
        "mjsteinbaugh",
        "rob-p" ;
    schema1:citation "doi:10.1038/nmeth.4197" ;
    schema1:description "Highly-accurate & wicked fast transcript-level quantification from RNA-seq reads (salmon 2.0, Rust)." ;
    schema1:downloadUrl "https://github.com/COMBINE-lab/salmon/archive/refs/tags/v2.1.1.tar.gz" ;
    schema1:identifier biotools:salmon ;
    schema1:license "BSD-3-Clause" ;
    schema1:maintainer "k3yavi",
        "mjsteinbaugh",
        "rob-p" ;
    schema1:name "salmon" ;
    schema1:softwareHelp "https://combine-lab.github.io/salmon" ;
    schema1:softwareVersion "2.1.1" ;
    schema1:url "https://github.com/COMBINE-lab/salmon" .

