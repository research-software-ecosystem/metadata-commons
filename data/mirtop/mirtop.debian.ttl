        bioconda:mirtop,
        "omictools:OMICS_31718" ;
    schema1:license "unknown" ;
    schema1:name "mirtop" ;
    schema1:softwareVersion "0.4.30" ;
    schema1:url "https://github.com/miRTop/mirtop" .

