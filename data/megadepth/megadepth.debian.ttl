@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .

debianmed:megadepth a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btab152" ;
    schema1:identifier biotools:megadepth,
        bioconda:megadepth ;
    schema1:license "unknown" ;
    schema1:name "megadepth" ;
    schema1:softwareVersion "1.2.0" ;
    schema1:url "https://github.com/ChristopherWilks/megadepth" .

