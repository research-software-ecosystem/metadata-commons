        bioconda:bowtie2,
        guix:bowtie,
        scicrunch:SCR_005476,
        "omictools:OMICS_31633" ;
    schema1:license "unknown" ;
    schema1:name "bowtie2" ;
    schema1:softwareVersion "2.5.5" ;
    schema1:url "https://bowtie-bio.sourceforge.net/bowtie2" .

