@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

bioconda:toulligqc a schema1:SoftwareApplication ;
    schema1:description "A post sequencing QC tool for Oxford Nanopore sequencers." ;
    schema1:downloadUrl "https://pypi.org/packages/source/t/toulligqc/toulligqc-2.9.1.tar.gz" ;
    schema1:identifier biotools:ToulligQC ;
    schema1:license "GPL-3.0-or-later" ;
    schema1:name "toulligqc" ;
    schema1:softwareHelp "https://github.com/GenomiqueENS/toulligQC/blob/v2.9.1/README.md" ;
    schema1:softwareVersion "2.9.1" ;
    schema1:url "https://github.com/GenomicParisCentre/toulligQC" .

