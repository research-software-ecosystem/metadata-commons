@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix guix: <https://packages.guix.gnu.org/packages/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:bwa a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp324" ;
    schema1:identifier biotools:bwa,
        bioconda:bwa,
        guix:bwa,
        scicrunch:SCR_010910,
        "omictools:OMICS_00654" ;
    schema1:keywords "biology::nuceleic-acids",
        "biology::peptidic",
        "field::biology",
        "field::biology:bioinformatics",
        "implemented-in::c",
        "interface::commandline",
        "interface::text-mode",
        "role::program",
        "use::analysing",
        "use::comparing" ;
    schema1:license "unknown" ;
    schema1:name "bwa" ;
    schema1:softwareVersion "0.7.19" ;
    schema1:url "https://bio-bwa.sourceforge.net/" .

