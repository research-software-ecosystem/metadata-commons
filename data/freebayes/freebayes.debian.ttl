        bioconda:freebayes,
        scicrunch:SCR_010761,
        "omictools:OMICS_00059" ;
    schema1:license "unknown" ;
    schema1:name "freebayes" ;
    schema1:softwareVersion "1.3.9" ;
    schema1:url "https://github.com/ekg/freebayes" .

