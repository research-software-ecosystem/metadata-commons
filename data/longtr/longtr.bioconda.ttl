@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

bioconda:longtr a schema1:SoftwareApplication ;
    schema1:author "awgymer" ;
    schema1:description "Tandem repeat genotyping with long reads." ;
    schema1:downloadUrl "https://github.com/google/googletest/archive/release-1.10.0.zip",
        "https://github.com/gymrek-lab/LongTR/archive/refs/tags/v1.2.tar.gz" ;
    schema1:identifier biotools:longtr ;
    schema1:license "BSD-2-Clause" ;
    schema1:maintainer "awgymer" ;
    schema1:name "longtr" ;
    schema1:softwareHelp "https://github.com/gymrek-lab/LongTR" ;
    schema1:softwareVersion "1.2" ;
    schema1:url "https://github.com/gymrek-lab/LongTR" .

