@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:figtree a schema1:SoftwareApplication ;
    schema1:identifier biotools:figtree,
        bioconda:figtree,
        scicrunch:SCR_008515,
        "omictools:OMICS_04268" ;
    schema1:license "unknown" ;
    schema1:name "figtree" ;
    schema1:softwareVersion "1.4.4" ;
    schema1:url "http://tree.bio.ed.ac.uk/software/figtree/" .

