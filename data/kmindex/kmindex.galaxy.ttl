@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix galaxytool: <https://github.com/galaxyproject/tools-iuc/tree/master/tools/> .
@prefix schema1: <http://schema.org/> .

galaxytool:kmindex a schema1:SoftwareApplication ;
    schema1:description "Index and query k-mers from sequencing samples using Bloom filters" ;
    schema1:identifier biotools:kmindex,
        bioconda:kmindex ;
    schema1:keywords "Sequence Analysis" ;
    schema1:name "kmindex" ;
    schema1:softwareVersion "0.6.0" ;
    schema1:url "https://github.com/tlemane/kmindex" .

