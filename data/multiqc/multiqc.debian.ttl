@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:multiqc a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw354" ;
    schema1:identifier biotools:multiqc,
        bioconda:multiqc,
        scicrunch:SCR_014982,
        "omictools:OMICS_12426" ;
    schema1:license "unknown" ;
    schema1:name "multiqc" ;
    schema1:softwareVersion "1.21" ;
    schema1:url "https://multiqc.info/" .

