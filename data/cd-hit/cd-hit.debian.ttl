@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:cd-hit a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btl158" ;
    schema1:identifier biotools:cd-hit,
        bioconda:cd-hit,
        scicrunch:SCR_007105,
        "omictools:OMICS_05157" ;
    schema1:license "unknown" ;
    schema1:name "cd-hit" ;
    schema1:softwareVersion "4.8.1" ;
    schema1:url "http://weizhongli-lab.org/cd-hit/" .

