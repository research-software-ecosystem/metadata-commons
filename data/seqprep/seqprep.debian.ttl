@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:seqprep a schema1:SoftwareApplication ;
    schema1:identifier biotools:seqprep,
        bioconda:seqprep,
        scicrunch:SCR_013004,
        "omictools:OMICS_01092" ;
    schema1:license "unknown" ;
    schema1:name "seqprep" ;
    schema1:softwareVersion "1.3.2" ;
    schema1:url "http://seqanswers.com/wiki/SeqPrep" .

