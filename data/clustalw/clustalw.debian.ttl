        scicrunch:SCR_002909,
        "omictools:OMICS_02562" ;
    schema1:keywords "biology::format:aln",
        "biology::nuceleic-acids",
        "biology::peptidic",
        "field::biology",
        "field::biology:bioinformatics",
        "implemented-in::c++",
        "interface::commandline",
        "interface::text-mode",
        "role::program",
        "scope::utility",
        "use::comparing",
        "works-with-format::plaintext",
        "works-with::TODO" ;
    schema1:license "unknown" ;
    schema1:name "clustalw" ;
    schema1:softwareVersion "2.1" ;
    schema1:url "http://www.clustal.org/clustal2/" .

