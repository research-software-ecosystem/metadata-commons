@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .

debianmed:quast a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btt086",
        "doi:10.1093/bioinformatics/btw379",
        "doi:10.1093/bioinformatics/bty266" ;
    schema1:identifier biotools:quast,
        bioconda:quast ;
    schema1:license "GPL-2" ;
    schema1:name "quast" ;
    schema1:softwareVersion "5.0.2" ;
    schema1:url "http://bioinf.spbau.ru/quast" .

