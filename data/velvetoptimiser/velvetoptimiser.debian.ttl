@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .

debianmed:velvetoptimiser a schema1:SoftwareApplication ;
    schema1:identifier biotools:velvetoptimiser,
        bioconda:perl-velvetoptimiser,
        "omictools:OMICS_14601" ;
    schema1:license "unknown" ;
    schema1:name "velvetoptimiser" ;
    schema1:softwareVersion "2.2.6" ;
    schema1:url "https://github.com/tseemann/VelvetOptimiser/" .

