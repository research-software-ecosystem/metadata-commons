@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .

debianmed:mosdepth a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btx699" ;
    schema1:identifier biotools:mosdepth,
        bioconda:mosdepth ;
    schema1:license "unknown" ;
    schema1:name "mosdepth" ;
    schema1:softwareVersion "0.3.11+ds" ;
    schema1:url "https://github.com/brentp/mosdepth" .

