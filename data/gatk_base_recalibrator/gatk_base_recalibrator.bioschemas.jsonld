        "Linux",
        "Mac",
        "Windows"
      ],
      "sc:softwareHelp": {
        "@id": "https://software.broadinstitute.org/gatk/documentation/tooldocs/3.8-0/org_broadinstitute_gatk_tools_walkers_bqsr_BaseRecalibrator.php"
      },
      "sc:softwareVersion": "2.4-9",
      "sc:url": "https://software.broadinstitute.org/gatk/"
    },
