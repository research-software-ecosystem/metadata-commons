@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .

debianmed:snpomatic a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btp403" ;
    schema1:identifier biotools:snp-o-matic,
        bioconda:snpomatic,
        "omictools:OMICS_15114" ;
    schema1:license "unknown" ;
    schema1:name "snpomatic" ;
    schema1:softwareVersion "1.0" ;
    schema1:url "https://github.com/magnusmanske/snpomatic" .

