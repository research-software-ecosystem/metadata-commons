@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:bio-tradis a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btw022" ;
    schema1:identifier biotools:bio-tradis,
        bioconda:biotradis,
        scicrunch:SCR_015993,
        "omictools:OMICS_11083" ;
    schema1:license "unknown" ;
    schema1:name "bio-tradis" ;
    schema1:softwareVersion "1.4.5" ;
    schema1:url "https://github.com/sanger-pathogens/Bio-Tradis" .

