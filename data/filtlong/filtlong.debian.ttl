@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .

debianmed:filtlong a schema1:SoftwareApplication ;
    schema1:identifier biotools:filtlong,
        bioconda:filtlong ;
    schema1:license "unknown" ;
    schema1:name "filtlong" ;
    schema1:softwareVersion "0.3.1" ;
    schema1:url "https://github.com/rrwick/Filtlong" .

