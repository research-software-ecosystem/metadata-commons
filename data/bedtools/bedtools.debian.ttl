@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix guix: <https://packages.guix.gnu.org/packages/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:bedtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btq033" ;
    schema1:identifier biotools:bedtools,
        bioconda:biotools,
        guix:bedtools,
        scicrunch:SCR_006646,
        "omictools:OMICS_01159" ;
    schema1:keywords "field::biology",
        "field::biology:bioinformatics",
        "implemented-in::c++",
        "interface::commandline",
        "role::program",
        "scope::suite",
        "use::analysing",
        "use::comparing",
        "use::converting",
        "use::filtering",
        "works-with::biological-sequence" ;
    schema1:license "unknown" ;
    schema1:name "bedtools" ;
    schema1:softwareVersion "2.31.1" ;
    schema1:url "https://github.com/arq5x/bedtools2" .

