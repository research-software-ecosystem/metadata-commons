@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix guix: <https://packages.guix.gnu.org/packages/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:bowtie a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1186/gb-2009-10-3-r25" ;
    schema1:identifier biotools:bowtie,
        bioconda:bowtie,
        guix:bowtie1,
        scicrunch:SCR_005476,
        "omictools:OMICS_00653" ;
    schema1:keywords "biology::nuceleic-acids",
        "field::biology:bioinformatics",
        "implemented-in::c++",
        "interface::commandline",
        "role::program",
        "science::calculation",
        "scope::utility",
        "use::analysing",
        "use::comparing",
        "works-with::biological-sequence" ;
    schema1:license "unknown" ;
    schema1:name "bowtie" ;
    schema1:softwareVersion "1.3.1" ;
    schema1:url "https://bowtie-bio.sourceforge.net/" .

