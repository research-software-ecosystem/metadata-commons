@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

bioconda:raxml-ng a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btz305" ;
    schema1:description "RAxML Next Generation: faster, easier-to-use and more flexible." ;
    schema1:downloadUrl "https://github.com/amkozlov/raxml-ng/releases/download/2.0.2/raxml-ng_v2.0.2_source.zip" ;
    schema1:identifier biotools:RAxML-NG ;
    schema1:license "AGPL-3.0-or-later" ;
    schema1:name "raxml-ng" ;
    schema1:softwareVersion "2.0.2" ;
    schema1:url "https://github.com/amkozlov/raxml-ng" .

