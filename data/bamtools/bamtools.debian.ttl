@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix guix: <https://packages.guix.gnu.org/packages/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:bamtools a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btr174" ;
    schema1:identifier biotools:bamtools,
        bioconda:bamtools,
        guix:bamtools,
        scicrunch:SCR_015987,
        "omictools:OMICS_11315" ;
    schema1:license "unknown" ;
    schema1:name "bamtools" ;
    schema1:softwareVersion "2.5.3" ;
    schema1:url "https://github.com/pezmaster31/bamtools/wiki" .

