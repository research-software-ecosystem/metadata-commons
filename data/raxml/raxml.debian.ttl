        "doi:10.1093/bioinformatics/btu033" ;
    schema1:identifier biotools:raxml,
        bioconda:raxml,
        scicrunch:SCR_006086 ;
    schema1:keywords "field::biology",
        "role::program" ;
    schema1:license "unknown" ;
    schema1:name "raxml" ;
    schema1:softwareVersion "8.2.13" ;
    schema1:url "https://cme.h-its.org/exelixis/web/software/raxml/index.html" .

