    schema1:identifier biotools:ssake,
        bioconda:ssake,
        scicrunch:SCR_010753,
        "omictools:OMICS_00033" ;
    schema1:keywords "biology::nuceleic-acids",
        "field::biology",
        "implemented-in::perl",
        "implemented-in::python",
        "interface::shell",
        "role::program",
        "scope::utility",
        "use::analysing" ;
    schema1:license "unknown" ;
    schema1:name "ssake" ;
    schema1:softwareVersion "4.0.1" ;
    schema1:url "https://www.bcgsc.ca/platform/bioinfo/software/ssake" .

