    schema1:citation "doi:10.1093/bioinformatics/btq683" ;
    schema1:identifier biotools:sspace,
        bioconda:sspace,
        scicrunch:SCR_005056,
        "omictools:OMICS_00050" ;
    schema1:license "unknown" ;
    schema1:name "sspace" ;
    schema1:softwareVersion "2.1.1" ;
    schema1:url "https://github.com/nsoranzo/sspace_basic" .

