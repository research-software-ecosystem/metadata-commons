@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:picard-tools a schema1:SoftwareApplication ;
    schema1:identifier biotools:picard_tools,
        bioconda:picard,
        scicrunch:SCR_006525,
        "omictools:OMICS_01066" ;
    schema1:license "unknown" ;
    schema1:name "picard-tools" ;
    schema1:softwareVersion "3.4.0" ;
    schema1:url "https://broadinstitute.github.io/picard/" .

