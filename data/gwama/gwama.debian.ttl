@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:gwama a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1002/gepi.20540",
        "doi:10.1186/1471-2105-11-288" ;
    schema1:identifier biotools:gwama,
        bioconda:gwama,
        scicrunch:SCR_006624,
        "omictools:OMICS_00235" ;
    schema1:license "unknown" ;
    schema1:name "gwama" ;
    schema1:softwareVersion "2.2.2" ;
    schema1:url "https://genomics.ut.ee/en/tools" .

