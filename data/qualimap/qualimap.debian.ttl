@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:qualimap a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/bts503" ;
    schema1:identifier biotools:qualimap,
        bioconda:qualimap,
        scicrunch:SCR_001209,
        "omictools:OMICS_02133" ;
    schema1:license "GPL-2+" ;
    schema1:name "qualimap" ;
    schema1:softwareVersion "2.2.1" ;
    schema1:url "http://qualimap.bioinfo.cipf.es/" .

