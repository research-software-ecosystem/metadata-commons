@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix schema1: <http://schema.org/> .

bioconda:svanna a schema1:SoftwareApplication ;
    schema1:author "nourmahfel" ;
    schema1:citation "doi:10.1186/s13073-022-01046-6" ;
    schema1:description "Efficient and accurate pathogenicity prediction for coding and regulatory structural variants in long-read genome sequencing" ;
    schema1:downloadUrl "https://github.com/monarch-initiative/SvAnna/releases/download/v1.2.0/svanna-cli-1.2.0-distribution.zip" ;
    schema1:identifier biotools:svanna ;
    schema1:license "LicenseRef-Jackson-Laboratory-NonCommercial" ;
    schema1:maintainer "nourmahfel" ;
    schema1:name "svanna" ;
    schema1:softwareHelp "https://svanna.readthedocs.io" ;
    schema1:softwareVersion "1.2.0" ;
    schema1:url "https://github.com/monarch-initiative/SvAnna" .

