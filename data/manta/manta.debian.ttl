@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .

debianmed:manta a schema1:SoftwareApplication ;
    schema1:citation "doi:10.1093/bioinformatics/btv710" ;
    schema1:identifier biotools:manta_sv,
        bioconda:manta,
        "omictools:OMICS_09180" ;
    schema1:license "GPL-3+" ;
    schema1:name "manta" ;
    schema1:softwareVersion "1.6.0" ;
    schema1:url "https://github.com/Illumina/manta" .

