@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix edam: <http://edamontology.org/> .
@prefix galaxytool: <https://github.com/galaxyproject/tools-iuc/tree/master/tools/> .
@prefix schema1: <http://schema.org/> .

galaxytool:kmetashot a schema1:SoftwareApplication ;
    schema1:applicationSubCategory edam:topic_3174 ;
    schema1:description "an alignment-free taxonomic classifier based on k-mer/minimizer counting" ;
    schema1:identifier biotools:kmetashot,
        bioconda:kmetashot ;
    schema1:keywords "Metagenomics" ;
    schema1:name "kmetashot" ;
    schema1:softwareVersion "2.0" ;
    schema1:url "https://github.com/gdefazio/kMetaShot" .

