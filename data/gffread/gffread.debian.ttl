@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .

debianmed:gffread a schema1:SoftwareApplication ;
    schema1:identifier biotools:gffread,
        bioconda:gffread,
        "omictools:OMICS_28050" ;
    schema1:license "unknown" ;
    schema1:name "gffread" ;
    schema1:softwareVersion "0.12.7" ;
    schema1:url "https://ccb.jhu.edu/software/stringtie/gff.shtml" .

