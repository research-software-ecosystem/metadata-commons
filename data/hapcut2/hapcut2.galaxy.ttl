@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix edam: <http://edamontology.org/> .
@prefix galaxytool: <https://github.com/galaxyproject/tools-iuc/tree/master/tools/> .
@prefix schema1: <http://schema.org/> .

galaxytool:hapcut2 a schema1:SoftwareApplication ;
    schema1:description "Robust and accurate haplotype assembly for diverse sequencing technologies" ;
    schema1:featureList edam:operation_0487,
        edam:operation_3225 ;
    schema1:identifier biotools:hapcut2,
        bioconda:hapcut2 ;
    schema1:keywords "Assembly" ;
    schema1:name "hapcut2" ;
    schema1:softwareVersion "1.3.4" ;
    schema1:url "https://github.com/vibansal/HapCUT2" .

