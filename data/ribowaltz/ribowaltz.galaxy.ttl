@prefix bioconda: <https://bioconda.github.io/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix edam: <http://edamontology.org/> .
@prefix galaxytool: <https://github.com/galaxyproject/tools-iuc/tree/master/tools/> .
@prefix schema1: <http://schema.org/> .

galaxytool:ribowaltz a schema1:SoftwareApplication ;
    schema1:applicationSubCategory edam:topic_3307 ;
    schema1:description "Calculation of optimal P-site offsets, diagnostic analysis and visual inspection of ribosome profiling data" ;
    schema1:identifier biotools:riboWaltz,
        bioconda:ribowaltz ;
    schema1:keywords "RNA",
        "Transcriptomics" ;
    schema1:name "ribowaltz" ;
    schema1:softwareVersion "1.2.0" ;
    schema1:url "https://github.com/LabTranslationalArchitectomics/riboWaltz" .

