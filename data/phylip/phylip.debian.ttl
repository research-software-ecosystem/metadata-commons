@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:phylip a schema1:SoftwareApplication ;
    schema1:identifier biotools:phylip,
        bioconda:phylip,
        scicrunch:SCR_006244,
        "omictools:OMICS_04240" ;
    schema1:keywords "field::biology",
        "field::biology:bioinformatics",
        "implemented-in::c",
        "interface::commandline",
        "role::program",
        "scope::utility",
        "use::analysing",
        "use::comparing",
        "works-with-format::plaintext",
        "works-with::TODO" ;
    schema1:license "unknown" ;
    schema1:name "phylip" ;
    schema1:softwareVersion "3.697" ;
    schema1:url "https://evolution.genetics.washington.edu/phylip.html" .

