@prefix bioconda: <https://github.com/bioconda/bioconda-recipes/tree/master/recipes/> .
@prefix biotools: <https://bio.tools/> .
@prefix debianmed: <https://salsa.debian.org/med-team/> .
@prefix schema1: <http://schema.org/> .
@prefix scicrunch: <https://scicrunch.org/resolver/> .

debianmed:fastqc a schema1:SoftwareApplication ;
    schema1:identifier biotools:fastqc,
        bioconda:fastqc,
        scicrunch:SCR_014583,
        "omictools:OMICS_01043" ;
    schema1:license "unknown" ;
    schema1:name "fastqc" ;
    schema1:softwareVersion "0.12.1" ;
    schema1:url "https://www.bioinformatics.babraham.ac.uk/projects/fastqc/" .

