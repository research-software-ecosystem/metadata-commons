        bioconda:stringtie,
        scicrunch:SCR_016323,
        "omictools:OMICS_07226" ;
    schema1:license "unknown" ;
    schema1:name "stringtie" ;
    schema1:softwareVersion "3.0.3+ds" ;
    schema1:url "https://ccb.jhu.edu/software/stringtie/" .

